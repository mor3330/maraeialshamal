# Supabase Configuration
# احصل على هذه القيم من: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ملاحظة: 
# 1. انسخ هذا الملف إلى .env.local
# 2. استبدل القيم بالقيم الحقيقية من مشروع Supabase الخاص بك
# 3. لا ترفع ملف .env.local إلى Git (موجود في .gitignore)
